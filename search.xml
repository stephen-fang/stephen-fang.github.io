        <content type="html"><![CDATA[<p>用split()就可以</p><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><span class="line"><span class="meta">&gt;&gt;&gt; </span>text = <span class="string">&#x27;   foo\tbar\r\nFred  Nurke\t Joe Smith\n\n&#x27;</span></span><br><span class="line"><span class="meta">&gt;&gt;&gt; </span><span class="string">&#x27; &#x27;</span>.join(text.split())</span><br><span class="line"><span class="string">&#x27;foo bar Fred Nurke Joe Smith&#x27;</span></span><br></pre></td></tr></table></figure>]]></content>
      
      
      
