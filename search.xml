    <entry>
      <title>生成器使用lambda</title>
      <link href="2021/12/03/%E7%94%9F%E6%88%90%E5%99%A8%E4%BD%BF%E7%94%A8lambda/"/>
      <url>2021/12/03/%E7%94%9F%E6%88%90%E5%99%A8%E4%BD%BF%E7%94%A8lambda/</url>
      
        <content type="html"><![CDATA[<figure class="highlight plaintext"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br></pre></td><td class="code"><pre><span class="line">lambda x: True if x % 2 == 0 else False</span><br><span class="line">注意def是语句而lambda是表达式</span><br><span class="line">下面这种情况下就只能用lambda而不能用def</span><br><span class="line">[(lambda x:x*x)(x) for x in range(1,11)]</span><br><span class="line"></span><br><span class="line">record = [(lambda x:(x[0], x[1]) if x[0] != x[1] else (x[0]))(e) for e in record]</span><br></pre></td></tr></table></figure>]]></content>
      
      
      
